{
  "manifest_version": 3,
  "name": "Leaf to Git",
  "version": "1.0",
  "description": "Extensão para sincronizar projetos do Overleaf com o GitHub.",
  "permissions": [
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "*://www.overleaf.com/*",
    "https://api.github.com/*",
    "https://codeload.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configurar GitHub"
  },
  "content_scripts": [
    {
      "matches": ["*://www.overleaf.com/project/*"],
      "js": ["content.js"]
    }
  ]
}
